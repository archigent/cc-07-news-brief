# News Brief Skill — 환경변수 템플릿
# 이 파일을 .env로 복사한 다음 본인 키 값으로 채우세요.
# .env 파일은 절대 깃허브에 커밋하지 마세요 (.gitignore에 .env 추가 의무)

# ─────────────────────────────────────────────
# 1. LLM API 키 — 아래 중 하나 선택
# OpenRouter 무료: https://openrouter.ai/keys
# Gemini 무료: https://aistudio.google.com/apikey
# Claude 유료: https://console.anthropic.com/
# GPT 유료: https://platform.openai.com/api-keys
# ─────────────────────────────────────────────
LLM_API_KEY=YOUR_LLM_API_KEY_HERE

# LLM 엔드포인트 (사용자 선택 LLM에 맞춰 변경)
LLM_ENDPOINT=https://openrouter.ai/api/v1/chat/completions

# LLM 모델 (저비용·무료 우선)
LLM_MODEL=openai/gpt-4o-mini

# ─────────────────────────────────────────────
# 2. Discord webhook 주소
# 본인 디스코드 서버 → 채널 설정 → 통합 → 웹후크 → URL 복사
# ─────────────────────────────────────────────
DISCORD_WEBHOOK_URL=YOUR_DISCORD_WEBHOOK_URL_HERE

# ─────────────────────────────────────────────
# 3. Google Sheets 누적 (Service Account 방식)
# console.cloud.google.com → 서비스 계정 생성 → JSON 키 다운로드
# 시트 "공유" → Service Account email 편집자 권한 필수
# ─────────────────────────────────────────────

# credentials.json 파일 전체 경로
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Google Sheets ID — sheets.google.com URL에서 추출
# docs.google.com/spreadsheets/d/[이 부분이 ID]/edit
SPREADSHEET_ID=YOUR_SPREADSHEET_ID_HERE

# ─────────────────────────────────────────────
# 4. 기타 옵션
# ─────────────────────────────────────────────

# 24시간 필터 시간 (기본 24, 매일 실행 시 24면 충분)
COLLECT_HOURS=24
